---
const steps = [
  { n: 'STEP 01', en: { title: 'Sign up in 2 minutes', desc: 'Create your account, add business details and set your PIN. No hardware needed.' }, sw: { title: 'Jisajili kwa dakika 2', desc: 'Fungua akaunti yako, ongeza taarifa za biashara na weka PIN. Hakuna vifaa vinavyohitajika.' } },
  { n: 'STEP 02', en: { title: 'Add your products', desc: 'Type products, scan existing barcodes, or import in bulk via spreadsheet.' }, sw: { title: 'Ongeza bidhaa zako', desc: 'Andika bidhaa, skani misimbo iliyopo, au ingiza kwa wingi kupitia lahajedwali.' } },
  { n: 'STEP 03', en: { title: 'Sell & see your profit', desc: 'Every sale shows real-time net profit. TRA receipt printed or sent automatically.' }, sw: { title: 'Uza na uone faida yako', desc: 'Kila mauzo yanaonyesha faida halisi ya wakati huo. Risiti ya TRA inachapwa au kutumwa moja kwa moja.' } },
];
---
<section class="sec sec-white">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="Inatumika vipi?" data-sw="Inatumika vipi?">Inatumika vipi?</span>
      <h2 data-en="Live in 3 steps" data-sw="Anza katika hatua 3">Live in 3 steps</h2>
      <p data-en="From sign-up to your first profitable sale — in minutes, no hardware required." data-sw="Kuanzia kujisajili hadi mauzo yako ya kwanza yenye faida — kwa dakika chache, bila vifaa.">From sign-up to your first profitable sale — in minutes, no hardware required.</p>
    </div>
    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <div class="n">{s.n}</div>
          <h3 data-en={s.en.title} data-sw={s.sw.title}>{s.en.title}</h3>
          <p data-en={s.en.desc} data-sw={s.sw.desc}>{s.en.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
