---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Pricing from '../components/Pricing.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { verticals, verticalSlugs } from '../data/verticals';

const appUrl = 'https://app.biashara-pos.com';

export async function getStaticPaths() {
  const { verticals, verticalSlugs } = await import('../data/verticals');
  return verticalSlugs.map((slug) => ({
    params: { vertical: slug },
    props: { v: verticals[slug] },
  }));
}

const { v } = Astro.props as { v: (typeof verticals)[keyof typeof verticals] };
const path = `/pos-for-${v.slug}`;

// Breadcrumb JSON-LD per page — small SEO assist.
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://biashara-pos.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://biashara-pos.com/#industries' },
    { '@type': 'ListItem', position: 3, name: v.name.en, item: `https://biashara-pos.com${path}` },
  ],
};

const otherVerticals = verticalSlugs.filter((s) => s !== v.slug).map((s) => verticals[s]);
---
<Layout
  title={v.seoTitle}
  description={v.seoDescription}
  path={path}
  faqs={v.faqs}
  extraJsonLd={[breadcrumbJsonLd]}
>
  <Nav />
  <main id="top">

    <!-- ============ VERTICAL HERO ============ -->
    <section class="hero hero-vertical">
      <div class="wrap vhero">
        <div class="vhero-copy reveal">
          <span class="eyebrow" data-en={`Built for ${v.name.en}`} data-sw={`Imejengwa kwa ${v.name.sw}`}>Built for {v.name.en}</span>
          <h1 data-en={v.headline.en} data-sw={v.headline.sw}>{v.headline.en}</h1>
          <p class="lead" data-en={v.heroSubhead.en} data-sw={v.heroSubhead.sw}>{v.heroSubhead.en}</p>
          <div class="hero-cta">
            <a class="btn btn-primary btn-lg" href={appUrl} data-en="Start for Free →" data-sw="Anza Bila Malipo →">Start for Free →</a>
            <a class="btn btn-ghost btn-lg" href="#features" data-en="See features" data-sw="Tazama vipengele">See features</a>
          </div>
          <div class="hero-ticks">
            <span class="tick"><span class="ic">✓</span><span data-en="TRA-compliant receipts" data-sw="Risiti zinazokubalika TRA">TRA-compliant receipts</span></span>
            <span class="tick"><span class="ic">✓</span><span data-en="Works offline" data-sw="Inafanya kazi bila intaneti">Works offline</span></span>
            <span class="tick"><span class="ic">✓</span><span data-en="Flat monthly fee" data-sw="Ada ya mwezi tu">Flat monthly fee</span></span>
          </div>
        </div>
        <div class="vhero-photo reveal">
          <Image
            src={v.photo}
            alt={v.alt}
            widths={[480, 720, 960]}
            sizes="(max-width: 880px) 100vw, 480px"
            loading="eager"
          />
          <span class={`vbadge v-${v.badgeKey}`} aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={v.features[0].icon} />
          </span>
        </div>
      </div>
    </section>

    <!-- ============ VERTICAL FEATURES ============ -->
    <section class="sec sec-tint" id="features">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="eyebrow center" data-en={`Why ${v.name.en} owners pick us`} data-sw="Kwa nini wanachagua sisi">Why {v.name.en} owners pick us</span>
          <h2 data-en={`Everything a ${v.name.en.toLowerCase()} business needs`} data-sw={`Kila kitu biashara ya ${v.name.sw.toLowerCase()} inahitaji`}>Everything a {v.name.en.toLowerCase()} business needs</h2>
        </div>
        <div class="fgrid fgrid-2">
          {v.features.map((feat, i) => (
            <div class={`feat reveal ${i % 2 === 1 ? 'blue' : ''}`}>
              <div class="fi" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${feat.icon}</svg>`} />
              <h3>{feat.title}</h3>
              <p>{feat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ INDUSTRY-LOCKED DASHBOARD MOCK ============ -->
    <section class="sec sec-white" id="preview">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="eyebrow center" data-en="See it in action" data-sw="Iangalie ikifanya kazi">See it in action</span>
          <h2 data-en={`${v.name.en} POS, end-to-end.`} data-sw={`POS ya ${v.name.sw}, kuanzia mwanzo.`}>{v.name.en} POS, end-to-end.</h2>
        </div>

        <div class="pos pos-locked reveal">
          <div class="pos-bar">
            <div class="pos-dots"><i style="background:#ec6a5e"></i><i style="background:#f4bf4f"></i><i style="background:#61c454"></i></div>
            <div class="pos-title">BiasharaPOS · {v.name.en}</div>
            <div class="pos-status"><span class="live"></span> TRA VFD synced</div>
          </div>
          <div class="pos-body">
            <div class="pos-main">
              <div class="pos-mhead">
                <div class="pos-cat">{v.name.en} · POS</div>
                <div class="pos-tag">{v.shortDesc.en}</div>
              </div>
              <div class="prod-grid prod-grid-static">
                {[0, 1, 2, 3].map((i) => {
                  const colors = ['#dbe7fb', '#e6f6ea', '#fbeedd', '#d9f0f6'];
                  return (
                    <div class="prod">
                      <div class="sw-img" style={`background:linear-gradient(135deg,${colors[i]},#ffffff)`} />
                      <div class="pn">{v.features[i].title}</div>
                      <div class="pp" data-en="In stock" data-sw="Ipo dukani">In stock</div>
                    </div>
                  );
                })}
              </div>
            </div>
            <div class="pos-side">
              <div class="profit-card">
                <div class="lbl" data-en="Net profit · this sale" data-sw="Faida halisi · mauzo haya">Net profit · this sale</div>
                <div class="amt">{v.sampleNet}</div>
                <div class="sub" data-en="after COGS · expenses · VAT" data-sw="baada ya gharama · matumizi · VAT">after COGS · expenses · VAT</div>
              </div>
              <div class="sum-card">
                <div class="sum-row"><span class="sum-k" data-en="Sales today" data-sw="Mauzo ya leo">Sales today</span><span class="sum-v">{v.sampleSales}</span></div>
                <div class="sum-row"><span class="sum-k" data-en="Transactions" data-sw="Miamala">Transactions</span><span class="sum-v">{v.sampleTx}</span></div>
              </div>
              <a class="btn btn-primary charge-btn" href={appUrl} data-en="Charge sale" data-sw="Toza mauzo">Charge sale</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Pricing />

    <!-- ============ VERTICAL FAQ ============ -->
    <section class="sec sec-tint" id="faq">
      <div class="wrap" style="max-width:880px;">
        <div class="sec-head reveal">
          <span class="eyebrow center" data-en={`${v.name.en} questions`} data-sw="Maswali">{v.name.en} questions</span>
          <h2 data-en="Frequently asked" data-sw="Maswali yanayoulizwa mara kwa mara">Frequently asked</h2>
        </div>
        <div class="faq-list" id="faqList">
          {v.faqs.map((f) => (
            <div class="faq">
              <button>
                <span>{f.q}</span>
                <span class="pls">+</span>
              </button>
              <div class="ans">
                <p>{f.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CROSS-LINKS TO OTHER VERTICALS ============ -->
    <section class="sec sec-white">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="eyebrow center" data-en="Run a different shop?" data-sw="Una biashara nyingine?">Run a different shop?</span>
          <h2 data-en="One POS, every vertical" data-sw="POS moja, kila sekta">One POS, every vertical</h2>
        </div>
        <div class="xlinks">
          {otherVerticals.map((o) => (
            <a class={`xlink reveal v-${o.badgeKey}`} href={`/pos-for-${o.slug}`}>
              <span class="xlink-name">{o.name.en}</span>
              <span class="xlink-desc">{o.shortDesc.en}</span>
              <span class="xlink-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>

<style is:global>
  /* ---------- vertical page hero ---------- */
  .hero-vertical { padding: 64px 0 56px; position: relative; }
  .hero-vertical::before {
    content: ""; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(58% 48% at 38% 0%, rgba(15,93,164,.10), transparent 70%),
      radial-gradient(46% 44% at 80% 16%, rgba(35,155,70,.08), transparent 70%);
  }
  .hero-vertical .wrap { position: relative; z-index: 1; }
  .vhero { display: grid; grid-template-columns: 1.05fr .95fr; gap: 56px; align-items: center; }
  .vhero-copy { display: flex; flex-direction: column; gap: 18px; align-items: flex-start; }
  .vhero-copy h1 { font-size: clamp(34px, 4.6vw, 54px); margin: 4px 0; }
  .vhero-copy .lead { font-size: 19px; }
  .vhero-copy .hero-cta { margin-top: 12px; }
  .vhero-copy .hero-ticks { margin-top: 8px; gap: 18px; }
  .vhero-photo {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    box-shadow: var(--sh-lg); aspect-ratio: 4 / 3; background: var(--green-50);
  }
  .vhero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vhero-photo .vbadge {
    position: absolute; top: 18px; left: 18px;
    width: 44px; height: 44px; border-radius: 12px;
    display: grid; place-items: center; color: #fff; box-shadow: var(--sh-md); z-index: 1;
  }
  .vhero-photo .vbadge svg { width: 24px; height: 24px; }
  @media (max-width: 880px) {
    .vhero { grid-template-columns: 1fr; gap: 32px; }
    .vhero-photo { max-width: 560px; margin: 0 auto; }
  }

  /* features grid override on vertical pages: 2 columns wide */
  .fgrid-2 { grid-template-columns: repeat(2, 1fr); max-width: 980px; margin: 0 auto; }
  @media (max-width: 880px) { .fgrid-2 { grid-template-columns: 1fr; } }

  /* prod grid with 4 placeholder items (no switcher) */
  .prod-grid-static { grid-template-columns: repeat(2, 1fr); }

  /* cross-link cards */
  .xlinks {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; max-width: 980px; margin: 0 auto;
  }
  .xlink {
    display: flex; flex-direction: column; gap: 4px; padding: 20px;
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--r);
    transition: transform .16s, box-shadow .2s, border-color .2s;
    position: relative; overflow: hidden;
  }
  .xlink::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
  }
  .xlink.v-cloth::before  { background: linear-gradient(180deg,#0f5da4,#2faee4); }
  .xlink.v-retail::before { background: linear-gradient(180deg,#239b46,#1b7c34); }
  .xlink.v-resto::before  { background: linear-gradient(180deg,#e7a52c,#f4b53e); }
  .xlink.v-hosp::before   { background: linear-gradient(180deg,#10977c,#2faee4); }
  .xlink.v-pharm::before  { background: linear-gradient(180deg,#0c4a85,#239b46); }
  .xlink:hover { transform: translateY(-4px); box-shadow: var(--sh-md); border-color: var(--green-100); }
  .xlink-name { font-size: 17px; font-weight: 800; color: var(--ink); }
  .xlink-desc { font-size: 13.5px; color: var(--ink-3); }
  .xlink-arrow { margin-top: 6px; font-weight: 800; color: var(--green-d); }
  @media (max-width: 1080px) { .xlinks { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .xlinks { grid-template-columns: 1fr; } }
</style>
