---
const appUrl = 'https://app.biashara-pos.com';
const plans = [
  {
    pop: false,
    en: { name: 'Free', price: 'TZS 0', per: '/mo', meta: '1 user · 1 device', features: ['Basic POS', 'Sales tracking', 'Cash payments', 'Daily sales report'], cta: 'Get started' },
    sw: { name: 'Bure', price: 'TZS 0', per: '/mw', meta: 'Mtumiaji 1 · Kifaa 1', features: ['POS ya msingi', 'Ufuatiliaji wa mauzo', 'Malipo ya pesa taslimu', 'Ripoti ya mauzo ya kila siku'], cta: 'Anza' },
    btn: 'btn-ghost',
  },
  {
    pop: true,
    en: { name: 'Pro', price: 'TZS 35k', per: '/mo', meta: '3 users · 2 devices', features: ['Everything in Free', 'Real-time profit dashboard', 'TRA audit PDF reports', 'VFD fiscal receipts', 'Inventory alerts', 'M-Pesa, Mixx by Yas, Airtel, Visa, MC'], cta: 'Start Pro trial' },
    sw: { name: 'Pro', price: 'TZS 35k', per: '/mw', meta: 'Watumiaji 3 · Vifaa 2', features: ['Vyote vya Bure', 'Dashibodi ya faida ya wakati huo', 'Ripoti za ukaguzi wa TRA PDF', 'Risiti za kodi VFD', 'Tahadhari za stoki', 'M-Pesa, Mixx by Yas, Airtel, Visa, MC'], cta: 'Anza Pro' },
    btn: 'btn-primary',
  },
  {
    pop: false,
    en: { name: 'Business', price: 'TZS 85k', per: '/mo', meta: '10 users · 5 devices', features: ['Everything in Pro', 'Expiry date tracking', 'Purchase orders', 'Pharmacy & restaurant mode', 'Advanced analytics', 'Priority support'], cta: 'Start trial' },
    sw: { name: 'Biashara', price: 'TZS 85k', per: '/mw', meta: 'Watumiaji 10 · Vifaa 5', features: ['Vyote vya Pro', 'Ufuatiliaji wa tarehe ya mwisho', 'Maagizo ya ununuzi', 'Hali ya duka la dawa na mgahawa', 'Uchanganuzi wa hali ya juu', 'Msaada wa kipaumbele'], cta: 'Anza majaribio' },
    btn: 'btn-ghost',
  },
  {
    pop: false,
    en: { name: 'Enterprise', price: 'Custom', per: '', meta: 'Unlimited users & devices', features: ['Everything in Business', 'Multi-branch management', 'White-label branding', 'Dedicated support', 'Custom integrations · SLA'], cta: 'Contact us' },
    sw: { name: 'Biashara Kubwa', price: 'Maalumu', per: '', meta: 'Watumiaji & vifaa visivyo na kikomo', features: ['Vyote vya Biashara', 'Usimamizi wa matawi mengi', 'Chapa ya kibinafsi', 'Msaada wa kujitolea', 'Muunganisho maalumu · SLA'], cta: 'Wasiliana' },
    btn: 'btn-ghost',
  },
];
---
<section class="sec sec-tint" id="pricing">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="Simple pricing" data-sw="Bei rahisi">Simple pricing</span>
      <h2 data-en="Flat monthly. Big value." data-sw="Ada moja kwa mwezi. Thamani kubwa.">Flat monthly. Big value.</h2>
      <p
        data-en='Start free. Upgrade when you&#39;re ready. No per-transaction fees, ever. <span class="sw">Bei rahisi, thamani kubwa.</span>'
        data-sw='Anza bila malipo. Pandisha unapokuwa tayari. Hakuna ada za kila muamala, kamwe. <span class="sw">Bei rahisi, thamani kubwa.</span>'
      >Start free. Upgrade when you're ready. No per-transaction fees, ever. <span class="sw">Bei rahisi, thamani kubwa.</span></p>
    </div>
    <div class="price-grid">
      {plans.map((p) => (
        <div class={`plan reveal ${p.pop ? 'pop' : ''}`}>
          {p.pop && (<span class="tagpop" data-en="★ Most popular" data-sw="★ Maarufu zaidi">★ Most popular</span>)}
          <div>
            <div class="pname" data-en={p.en.name} data-sw={p.sw.name}>{p.en.name}</div>
            <div class="pprice">
              <span data-en={p.en.price} data-sw={p.sw.price}>{p.en.price}</span>{p.en.per && (<small data-en={p.en.per} data-sw={p.sw.per}>{p.en.per}</small>)}
            </div>
          </div>
          <div class="pmeta" data-en={p.en.meta} data-sw={p.sw.meta}>{p.en.meta}</div>
          <ul>
            {p.en.features.map((feat, i) => (
              <li data-en={feat} data-sw={p.sw.features[i]}>{feat}</li>
            ))}
          </ul>
          <a class={`btn ${p.btn}`} href={appUrl} data-en={p.en.cta} data-sw={p.sw.cta}>{p.en.cta}</a>
        </div>
      ))}
    </div>
  </div>
</section>
