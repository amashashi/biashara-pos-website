---
import { Image } from 'astro:assets';
import { verticals, verticalSlugs } from '../data/verticals';

const cardIcons: Record<string, string> = {
  clothing:  '<path d="M16 3l4 4-3 2v10H7V9L4 7l4-4 2 2h4l2-2z"/>',
  retail:    '<path d="M6 7h12l-1 13H7L6 7z"/><path d="M9 7a3 3 0 0 1 6 0"/>',
  restaurant:'<path d="M6 3v8a2 2 0 0 0 4 0V3M8 11v10M17 3c-2 0-3 2-3 5s1 4 3 4v9"/>',
  hospital:  '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M12 8v8M8 12h8"/>',
  pharmacy:  '<rect x="3" y="8" width="18" height="11" rx="2"/><path d="M7 8V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M12 11v5M9.5 13.5h5"/>',
};
---
<section class="sec sec-white" id="industries">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="Built for your floor" data-sw="Imejengwa kwa ajili yako">Built for your floor</span>
      <h2 data-en="Tuned for every vertical" data-sw="Imetengenezwa kwa kila sekta">Tuned for every vertical</h2>
      <p
        data-en='The same fast checkout, tailored to how your industry actually sells. <span class="sw">Kila biashara, mfumo mmoja.</span>'
        data-sw='Malipo haraka yale yale, yaliyobinafsishwa kwa jinsi sekta yako inavyouza. <span class="sw">Kila biashara, mfumo mmoja.</span>'
      >The same fast checkout, tailored to how your industry actually sells. <span class="sw">Kila biashara, mfumo mmoja.</span></p>
    </div>
    <div class="vgrid">
      {verticalSlugs.map((slug) => {
        const v = verticals[slug];
        return (
          <a class="vcard reveal" href={`/pos-for-${v.slug}`} aria-label={`${v.name.en} POS — learn more`}>
            <div class="vimg">
              <Image
                src={v.photo}
                alt={v.alt}
                widths={[320, 480, 640, 800]}
                sizes="(max-width: 560px) 100vw, (max-width: 880px) 50vw, (max-width: 1080px) 33vw, 220px"
                loading="lazy"
              />
              <span class={`vbadge v-${v.badgeKey}`} set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">${cardIcons[v.slug]}</svg>`}></span>
            </div>
            <div class="vbody">
              <h3 data-en={v.name.en} data-sw={v.name.sw}>{v.name.en}</h3>
              <p data-en={v.shortDesc.en} data-sw={v.shortDesc.sw}>{v.shortDesc.en}</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
