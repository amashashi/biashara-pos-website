---
const rows = [
  { sales: 'TZS 1,000,000', pesapal: 'TZS 35,000', biashara: 'TZS 35,000', saving: 'Break even', highlight: false },
  { sales: 'TZS 2,000,000', pesapal: 'TZS 70,000', biashara: 'TZS 35,000', saving: 'TZS 35,000 saved', highlight: false },
  { sales: 'TZS 5,000,000', pesapal: 'TZS 175,000', biashara: 'TZS 35,000', saving: 'TZS 140,000 saved', highlight: true },
  { sales: 'TZS 10,000,000', pesapal: 'TZS 350,000', biashara: 'TZS 35,000', saving: 'TZS 315,000 saved', highlight: false },
  { sales: 'TZS 20,000,000', pesapal: 'TZS 700,000', biashara: 'TZS 35,000', saving: 'TZS 665,000 saved', highlight: false },
];
---
<section class="py-20 bg-[#F8FAFC]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 fade-in">
      <p class="text-[#1D9E75] font-700 text-sm uppercase tracking-widest mb-3">Cost comparison</p>
      <h2 class="text-3xl sm:text-4xl font-800 text-[#1C1C1A]">
        <span data-en="Compare the cost" data-sw="Linganisha gharama">Compare the cost</span>
      </h2>
      <p class="mt-3 text-gray-500 font-600 text-lg">Linganisha gharama</p>
      <p class="mt-3 text-gray-500">Pesapal charges 3.5% per transaction. BiasharaPOS charges a flat monthly fee.</p>
    </div>

    <div class="fade-in overflow-x-auto rounded-2xl shadow-lg border border-gray-200">
      <table class="w-full border-collapse bg-white">
        <thead>
          <tr class="bg-[#1A56A0]">
            <th class="px-6 py-4 text-left text-sm font-700 text-white">Monthly Sales</th>
            <th class="px-6 py-4 text-center text-sm font-700 text-white">Pesapal 3.5%</th>
            <th class="px-6 py-4 text-center text-sm font-700 text-[#1D9E75] bg-[#0B3D2E]">BiasharaPOS Pro</th>
            <th class="px-6 py-4 text-center text-sm font-700 text-white">Monthly Saving</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class={`border-t border-gray-100 ${row.highlight ? 'bg-[#F0FDF4]' : 'hover:bg-gray-50'} transition-colors`}>
              <td class="px-6 py-4 text-sm font-600 text-[#1C1C1A]">
                {row.sales}
                {row.highlight && (
                  <span class="ml-2 text-[10px] bg-[#1D9E75] text-white px-2 py-0.5 rounded-full font-700 uppercase">Typical SME</span>
                )}
              </td>
              <td class="px-6 py-4 text-center text-sm font-600 text-red-600">{row.pesapal}</td>
              <td class="px-6 py-4 text-center text-sm font-800 text-[#1D9E75] bg-[#F0FDF4]">{row.biashara}</td>
              <td class={`px-6 py-4 text-center text-sm font-700 ${row.saving === 'Break even' ? 'text-gray-500' : 'text-[#1D9E75]'}`}>
                {row.saving}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-6 text-center fade-in">
      <p class="inline-block bg-[#1D9E75] text-white font-700 px-6 py-3 rounded-xl text-sm shadow-md">
        💰 At TZS 5M monthly sales, you save <strong>TZS 1,680,000/year</strong> with BiasharaPOS
      </p>
    </div>
  </div>
</section>
