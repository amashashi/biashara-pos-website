---
const rows = [
  { sales: 'TZS 1,000,000', label: '', comp: '35,000', us: '35,000', save: 'Break even', save_sw: 'Sawa', hl: false },
  { sales: 'TZS 2,000,000', label: '', comp: '70,000', us: '35,000', save: '+35,000', save_sw: '+35,000', hl: false },
  { sales: 'TZS 5,000,000', label: 'TYPICAL SME', label_sw: 'SME YA KAWAIDA', comp: '175,000', us: '35,000', save: '+140,000', save_sw: '+140,000', hl: true },
  { sales: 'TZS 10,000,000', label: '', comp: '350,000', us: '35,000', save: '+315,000', save_sw: '+315,000', hl: false },
  { sales: 'TZS 20,000,000', label: '', comp: '700,000', us: '35,000', save: '+665,000', save_sw: '+665,000', hl: false },
];
---
<section class="sec sec-tint">
  <div class="wrap cmp">
    <div class="reveal">
      <span class="eyebrow" data-en="Compare the cost" data-sw="Linganisha gharama">Compare the cost</span>
      <h2 data-en="Competitors take 3.5% per sale. We charge a flat fee." data-sw="Washindani wanatoza 3.5% kwa kila mauzo. Sisi tunatoza ada ya kawaida.">Competitors take 3.5% per sale. We charge a flat fee.</h2>
      <p class="lead" data-en="No per-transaction charges, no surprises — one predictable monthly price as your sales grow." data-sw="Hakuna ada za kila muamala, hakuna mshangao — bei moja ya kila mwezi inayoweza kutabiriwa biashara yako ikikua.">No per-transaction charges, no surprises — one predictable monthly price as your sales grow.</p>
      <div class="save-chip"><b>~TZS 1.68M</b><span data-en="saved per year at TZS 5M monthly sales" data-sw="zinazookolewa kwa mwaka kwa mauzo ya TZS 5M kwa mwezi">saved per year at TZS 5M monthly sales</span></div>
    </div>
    <div class="cmp-table reveal">
      <table>
        <thead>
          <tr>
            <th data-en="Monthly sales" data-sw="Mauzo kwa mwezi">Monthly sales</th>
            <th data-en="Competitors (3.5%)" data-sw="Washindani (3.5%)">Competitors (3.5%)</th>
            <th>BiasharaPOS</th>
            <th data-en="You save" data-sw="Unaokoa">You save</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr class={r.hl ? 'hl' : ''}>
              <td class="rowlab">
                {r.sales}
                {r.label && (<small data-en={r.label} data-sw={r.label_sw}>{r.label}</small>)}
              </td>
              <td class="comp">{r.comp}</td>
              <td class="us">{r.us}</td>
              <td class="save" data-en={r.save} data-sw={r.save_sw}>{r.save}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
