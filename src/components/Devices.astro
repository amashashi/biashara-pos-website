---
---
<section class="sec sec-tint devsec" id="devices">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="One account · every device" data-sw="Akaunti moja · kila kifaa">One account · every device</span>
      <h2 data-en="Sell on your phone, your counter, or your computer." data-sw="Uza kwa simu yako, kaunta yako, au kompyuta yako.">Sell on your phone, your counter, or your computer.</h2>
      <p
        data-en='Ring up a sale on the POS terminal, check it on your phone, run reports on your computer — it all syncs in real time. <span class="sw">Popote ulipo.</span>'
        data-sw='Toza mauzo kwenye POS terminal, angalia kwenye simu yako, endesha ripoti kwenye kompyuta — vyote vinasawazishwa wakati huo huo. <span class="sw">Popote ulipo.</span>'
      >Ring up a sale on the POS terminal, check it on your phone, run reports on your computer — it all syncs in real time. <span class="sw">Popote ulipo.</span></p>
    </div>
    <div style="text-align:center;margin-bottom:34px;" class="reveal">
      <span class="sync-pill"><span class="sd"></span> <span data-en="Real-time sync across all your devices" data-sw="Usawazishaji wa wakati halisi katika vifaa vyako vyote">Real-time sync across all your devices</span></span>
    </div>
    <div class="devstage">
      <!-- phone -->
      <div class="dev reveal">
        <div class="dev-phone">
          <div class="scrn">
            <div class="mini-bar"><div class="md"><i style="background:#ec6a5e"></i><i style="background:#f4bf4f"></i><i style="background:#61c454"></i></div><span class="mt">BiasharaPOS</span><span class="mst">● live</span></div>
            <div class="mini-profit"><div class="l" data-en="Net profit · this sale" data-sw="Faida halisi · mauzo haya">Net profit · this sale</div><div class="v">+TZS 4,200</div></div>
            <div class="mini-row"><span class="ic" style="background:linear-gradient(135deg,#dbe7fb,#fff)"></span><span class="nm">Cooking Oil 2L</span><span class="pr">9,500</span></div>
            <div class="mini-row"><span class="ic" style="background:linear-gradient(135deg,#e6f6ea,#fff)"></span><span class="nm">Rice 5kg</span><span class="pr">22,000</span></div>
            <div class="mini-btn" data-en="Charge sale" data-sw="Toza mauzo">Charge sale</div>
          </div>
        </div>
        <div class="cap"><b data-en="Mobile app" data-sw="App ya simu">Mobile app</b><span data-en="Sell on the go" data-sw="Uza popote">Sell on the go</span></div>
      </div>

      <!-- POS terminal -->
      <div class="dev reveal">
        <div class="dev-term">
          <div class="scrn">
            <div class="mini-bar"><span class="mt" data-en="Card payment" data-sw="Malipo ya kadi">Card payment</span><span class="mst">● VFD</span></div>
            <div class="term-amt"><div class="tl" data-en="Amount due" data-sw="Kiasi cha kulipa">Amount due</div><div class="tv">TZS 35,000</div></div>
            <div class="term-keys"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
            <div class="slot"></div>
          </div>
          <div class="tap" data-en="Tap, insert or swipe" data-sw="Gusa, ingiza au pita">Tap, insert or swipe</div>
        </div>
        <div class="cap"><b data-en="POS terminal" data-sw="POS terminal">POS terminal</b><span data-en="At the counter" data-sw="Kaunta">At the counter</span></div>
      </div>

      <!-- computer -->
      <div class="dev reveal">
        <div class="dev-comp">
          <div class="lid">
            <div class="scrn">
              <div class="mini-bar"><span class="mt" data-en="Back office · Today" data-sw="Ofisi · Leo">Back office · Today</span><span class="mst">● synced</span></div>
              <div class="comp-grid2">
                <div class="comp-bars"><i style="height:38%"></i><i style="height:55%"></i><i style="height:48%"></i><i style="height:70%"></i><i style="height:62%"></i><i class="hi" style="height:92%"></i></div>
                <div class="comp-chips">
                  <div class="comp-chip green"><div class="l" data-en="Net profit" data-sw="Faida halisi">Net profit</div><div class="v">TZS 312,400</div></div>
                  <div class="comp-chip"><div class="l" data-en="Sales today" data-sw="Mauzo ya leo">Sales today</div><div class="v">TZS 847,500</div></div>
                </div>
              </div>
            </div>
          </div>
          <div class="base"></div>
        </div>
        <div class="cap"><b data-en="Computer" data-sw="Kompyuta">Computer</b><span data-en="Reports & back office" data-sw="Ripoti na ofisi">Reports &amp; back office</span></div>
      </div>
    </div>
  </div>
</section>
