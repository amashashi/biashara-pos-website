---
// Set PUBLIC_CHAT_API_URL in your .env or Railway env vars after deployment
const apiUrl = import.meta.env.PUBLIC_CHAT_API_URL ?? '';
---

<!-- Floating chat button -->
<button id="chat-btn" aria-label="Open chat with Biashara Assistant">
  <svg id="chat-open-icon" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 2C6.477 2 2 6.145 2 11.25c0 2.547 1.11 4.847 2.9 6.497L4 21l4.2-1.75A10.3 10.3 0 0012 20.5c5.523 0 10-4.145 10-9.25S17.523 2 12 2z"/>
  </svg>
  <svg id="chat-close-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="display:none">
    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
  </svg>
</button>

<!-- Chat window -->
<div id="chat-window" aria-label="Biashara Assistant chat">
  <!-- Header -->
  <div id="chat-header">
    <div id="chat-avatar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
        <path d="M12 2C6.477 2 2 6.145 2 11.25c0 2.547 1.11 4.847 2.9 6.497L4 21l4.2-1.75A10.3 10.3 0 0012 20.5c5.523 0 10-4.145 10-9.25S17.523 2 12 2z"/>
      </svg>
    </div>
    <div>
      <div id="chat-title">Biashara Assistant</div>
      <div id="chat-subtitle">AI-powered support • Usually instant</div>
    </div>
  </div>

  <!-- Messages -->
  <div id="chat-messages"></div>

  <!-- Input row -->
  <div id="chat-footer">
    <input
      id="chat-input"
      type="text"
      placeholder="Ask about Biashara POS…"
      autocomplete="off"
    />
    <button id="chat-send" aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
      </svg>
    </button>
  </div>
</div>

<style is:global>
  /* ── Toggle button ─────────────────────────────── */
  #chat-btn {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #1A56A0;
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(26,86,160,0.4);
    transition: transform 0.2s, background 0.2s;
  }
  #chat-btn:hover { background: #154785; transform: scale(1.06); }

  /* ── Chat window ───────────────────────────────── */
  #chat-window {
    position: fixed;
    bottom: 92px;
    left: 24px;
    z-index: 9998;
    width: 360px;
    max-width: calc(100vw - 48px);
    height: 500px;
    max-height: calc(100vh - 120px);
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    display: none;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    animation: chatSlideUp 0.22s ease;
  }
  #chat-window.open { display: flex; }
  @keyframes chatSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Header ────────────────────────────────────── */
  #chat-header {
    background: #1A56A0;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  #chat-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  #chat-title {
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    line-height: 1.2;
  }
  #chat-subtitle {
    color: rgba(255,255,255,0.72);
    font-size: 11.5px;
    margin-top: 1px;
  }

  /* ── Messages area ─────────────────────────────── */
  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #F4F6F9;
    scroll-behavior: smooth;
  }
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }

  /* ── Bubbles ───────────────────────────────────── */
  .cm-user {
    align-self: flex-end;
    background: #1A56A0;
    color: #fff;
    padding: 9px 14px;
    border-radius: 16px 16px 4px 16px;
    max-width: 82%;
    font-size: 14px;
    line-height: 1.55;
    word-break: break-word;
    white-space: pre-wrap;
  }
  .cm-bot {
    align-self: flex-start;
    background: #fff;
    color: #1C1C1A;
    padding: 9px 14px;
    border-radius: 16px 16px 16px 4px;
    max-width: 82%;
    font-size: 14px;
    line-height: 1.55;
    word-break: break-word;
    white-space: pre-wrap;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
  }

  /* ── Typing dots ───────────────────────────────── */
  .cm-typing {
    align-self: flex-start;
    background: #fff;
    padding: 12px 16px;
    border-radius: 16px 16px 16px 4px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    display: flex;
    gap: 5px;
    align-items: center;
  }
  .cm-typing span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #94A3B8;
    animation: cmBounce 1.2s infinite;
  }
  .cm-typing span:nth-child(2) { animation-delay: 0.18s; }
  .cm-typing span:nth-child(3) { animation-delay: 0.36s; }
  @keyframes cmBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* ── Input row ─────────────────────────────────── */
  #chat-footer {
    display: flex;
    gap: 8px;
    padding: 10px 12px;
    border-top: 1px solid #E5E7EB;
    background: #fff;
    flex-shrink: 0;
  }
  #chat-input {
    flex: 1;
    padding: 9px 14px;
    border: 1.5px solid #D1D5DB;
    border-radius: 24px;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    color: #1C1C1A;
    background: #fff;
  }
  #chat-input:focus {
    border-color: #1A56A0;
    box-shadow: 0 0 0 3px rgba(26,86,160,0.12);
  }
  #chat-input:disabled { opacity: 0.6; }
  #chat-send {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #1A56A0;
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s;
  }
  #chat-send:hover:not(:disabled) { background: #154785; transform: scale(1.05); }
  #chat-send:disabled { opacity: 0.45; cursor: not-allowed; }
</style>

<script define:vars={{ apiUrl }}>
  const CHAT_API_URL = apiUrl; // Set PUBLIC_CHAT_API_URL in env to point to your deployed agent

  const btn        = document.getElementById('chat-btn');
  const win        = document.getElementById('chat-window');
  const messages   = document.getElementById('chat-messages');
  const input      = document.getElementById('chat-input');
  const sendBtn    = document.getElementById('chat-send');
  const openIcon   = document.getElementById('chat-open-icon');
  const closeIcon  = document.getElementById('chat-close-icon');

  let isOpen      = false;
  let isBusy      = false;
  let greeted     = false;
  const sessionId = sessionStorage.getItem('bpos-session') ?? crypto.randomUUID();
  sessionStorage.setItem('bpos-session', sessionId);

  // ── Open / close ──────────────────────────────────
  function toggle() {
    isOpen = !isOpen;
    win.classList.toggle('open', isOpen);
    openIcon.style.display  = isOpen ? 'none'  : 'block';
    closeIcon.style.display = isOpen ? 'block' : 'none';
    if (isOpen) {
      if (!greeted) { greet(); greeted = true; }
      input.focus();
    }
  }

  function greet() {
    addBot('👋 Hi! I\'m the Biashara POS assistant.\n\nAsk me anything about features, pricing, TRA compliance, offline mode, or how to get started — in English or Swahili!');
  }

  // ── Message helpers ───────────────────────────────
  function addUser(text) {
    const d = document.createElement('div');
    d.className = 'cm-user';
    d.textContent = text;
    messages.appendChild(d);
    scrollBottom();
    return d;
  }

  function addBot(text) {
    const d = document.createElement('div');
    d.className = 'cm-bot';
    d.textContent = text;
    messages.appendChild(d);
    scrollBottom();
    return d;
  }

  function showTyping() {
    const d = document.createElement('div');
    d.className = 'cm-typing';
    d.id = 'cm-typing';
    d.innerHTML = '<span></span><span></span><span></span>';
    messages.appendChild(d);
    scrollBottom();
  }

  function hideTyping() {
    document.getElementById('cm-typing')?.remove();
  }

  function scrollBottom() {
    messages.scrollTop = messages.scrollHeight;
  }

  function setBusy(busy) {
    isBusy = busy;
    input.disabled = busy;
    sendBtn.disabled = busy;
  }

  // ── Send ──────────────────────────────────────────
  async function send() {
    const text = input.value.trim();
    if (!text || isBusy) return;
    input.value = '';
    addUser(text);
    setBusy(true);
    showTyping();

    if (!CHAT_API_URL) {
      hideTyping();
      addBot('⚙️ The chat API is not configured yet. Please check back soon or email hello@biasharapos.com');
      setBusy(false);
      return;
    }

    try {
      const res = await fetch(`${CHAT_API_URL}/chat/stream`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId, message: text }),
      });

      if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

      hideTyping();
      const botDiv = addBot('');
      const reader  = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let gotText = false;

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() ?? '';
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const payload = line.slice(6);
          if (payload === '[DONE]') break;
          try {
            const parsed = JSON.parse(payload);
            if (parsed.text) {
              botDiv.textContent += parsed.text;
              gotText = true;
              scrollBottom();
            } else if (parsed.error) {
              botDiv.textContent = 'Something went wrong on my end. Please try again or email hello@biasharapos.com';
              gotText = true;
            }
          } catch { /* ignore malformed chunks */ }
        }
      }

      // Empty response — server-side issue (e.g. missing API key)
      if (!gotText) {
        botDiv.textContent = 'I didn\'t get a response. The service may be misconfigured — please email hello@biasharapos.com';
      }
    } catch (err) {
      hideTyping();
      addBot('Sorry, I couldn\'t reach the assistant right now. Please try again or email hello@biasharapos.com');
      console.error('Chat error:', err);
    } finally {
      setBusy(false);
      input.focus();
    }
  }

  // ── Events ────────────────────────────────────────
  btn.addEventListener('click', toggle);
  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
  });
</script>
