---
const apiUrl = import.meta.env.PUBLIC_CHAT_API_URL ?? '';
const WA = 'https://wa.me/255754711960?text=Hello%2C%20I%27m%20interested%20in%20BiasharaPOS';
---
<!-- Floating bot FAB (left) -->
<button class="fab fab-bot" id="botFab" aria-label="Open Biashara Bot chat" data-sw-aria="Fungua gumzo la Biashara Bot">
  <span class="pulse"></span>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 12a8 8 0 0 1-11.5 7.2L4 20.5l1.3-4.3A8 8 0 1 1 21 12z"/>
    <circle cx="9" cy="12" r="1" fill="currentColor" stroke="none"/>
    <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/>
    <circle cx="15" cy="12" r="1" fill="currentColor" stroke="none"/>
  </svg>
</button>
<span class="fab-tip tip-bot" data-en="Ask Biashara Bot" data-sw="Uliza Biashara Bot">Ask Biashara Bot</span>

<!-- Chat panel -->
<div class="chat-panel" id="chatPanel" role="dialog" aria-label="Biashara Bot chat">
  <div class="chat-head">
    <div class="ava">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="4" y="7" width="16" height="12" rx="3"/>
        <path d="M12 7V4M8.5 12h.01M15.5 12h.01M9 16h6"/>
      </svg>
    </div>
    <div class="ht">
      <b>Biashara Bot</b>
      <span><i></i> <span data-en="AI support · usually instant" data-sw="Msaada wa AI · papo hapo">AI support · usually instant</span></span>
    </div>
    <button class="cx" id="chatClose" aria-label="Close chat" data-sw-aria="Funga gumzo">×</button>
  </div>
  <div class="chat-body" id="chatBody"></div>
  <div class="chat-input">
    <input id="chatInput" type="text" placeholder="Type a message…" data-sw-placeholder="Andika ujumbe…" autocomplete="off" />
    <button class="send" id="chatSend" aria-label="Send message" data-sw-aria="Tuma ujumbe">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
      </svg>
    </button>
  </div>
</div>

<script define:vars={{ apiUrl, WA }}>
  // Wire to real backend (Railway agent) when configured; canned WhatsApp fallback otherwise.
  const CHAT_API_URL = apiUrl;
  const WA_URL = WA;

  const panel    = document.getElementById('chatPanel');
  const launch   = document.getElementById('botFab');
  const body     = document.getElementById('chatBody');
  const input    = document.getElementById('chatInput');
  const sendBtn  = document.getElementById('chatSend');
  const closeBtn = document.getElementById('chatClose');
  if (!panel || !launch || !body || !input || !sendBtn || !closeBtn) {
    // Defensive — if any element is missing, do nothing.
  } else {
    const pulse = launch.querySelector('.pulse');

    let isOpen   = false;
    let isBusy   = false;
    let greeted  = false;
    const sessionId = sessionStorage.getItem('bpos-session') ?? crypto.randomUUID();
    sessionStorage.setItem('bpos-session', sessionId);

    function openPanel() {
      panel.classList.add('open');
      isOpen = true;
      if (pulse) pulse.style.display = 'none';
      if (!greeted) { greeted = true; greet(); }
      input.focus();
    }
    function closePanel() {
      panel.classList.remove('open');
      isOpen = false;
    }
    launch.addEventListener('click', () => (isOpen ? closePanel() : openPanel()));
    closeBtn.addEventListener('click', closePanel);

    function scrollDown() { body.scrollTop = body.scrollHeight; }

    function botHTML(html) {
      const d = document.createElement('div');
      d.className = 'bubble bot';
      d.innerHTML = html;
      body.appendChild(d); scrollDown();
      return d;
    }
    function botText(text) {
      const d = document.createElement('div');
      d.className = 'bubble bot';
      d.textContent = text;
      body.appendChild(d); scrollDown();
      return d;
    }
    function meText(text) {
      const d = document.createElement('div');
      d.className = 'bubble me';
      d.textContent = text;
      body.appendChild(d); scrollDown();
      return d;
    }
    function showTyping() {
      const d = document.createElement('div');
      d.className = 'bubble bot';
      d.id = 'cm-typing';
      d.textContent = '…';
      body.appendChild(d); scrollDown();
    }
    function hideTyping() {
      const t = document.getElementById('cm-typing');
      if (t) t.remove();
    }

    function quickReplies(options) {
      const q = document.createElement('div');
      q.className = 'quick';
      options.forEach((o) => {
        const b = document.createElement('button');
        b.textContent = o.label;
        b.addEventListener('click', () => {
          q.remove();
          if (o.run) o.run();
          else send(o.label);
        });
        q.appendChild(b);
      });
      body.appendChild(q); scrollDown();
    }

    function greet() {
      setTimeout(() => {
        botHTML("Habari! 👋 I'm <b>Biashara Bot</b>. How can I help you grow your business today?");
        quickReplies([
          { label: 'See pricing' },
          { label: 'Is it TRA-compliant?' },
          { label: 'Works for my shop?' },
          {
            label: 'Talk to a human',
            run: () => {
              meText('Talk to a human');
              botHTML(
                'Of course — our team replies fast on WhatsApp.' +
                '<a class="wa-link" href="' + WA_URL + '" target="_blank" rel="noopener">Chat on WhatsApp →</a>'
              );
            },
          },
        ]);
      }, 300);
    }

    function setBusy(busy) {
      isBusy = busy;
      input.disabled = busy;
      sendBtn.disabled = busy;
    }

    async function send(textOverride) {
      const text = (typeof textOverride === 'string' ? textOverride : input.value || '').trim();
      if (!text || isBusy) return;
      input.value = '';
      meText(text);
      setBusy(true);
      showTyping();

      if (!CHAT_API_URL) {
        hideTyping();
        botHTML(
          'I\'m offline right now. Reach our team instantly on WhatsApp:' +
          '<a class="wa-link" href="' + WA_URL + '" target="_blank" rel="noopener">Chat on WhatsApp →</a>'
        );
        setBusy(false);
        return;
      }

      try {
        const res = await fetch(`${CHAT_API_URL}/chat/stream`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId, message: text }),
        });
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
        hideTyping();
        const botDiv = botText('');
        const reader  = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        let gotText = false;

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() ?? '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const payload = line.slice(6);
            if (payload === '[DONE]') break;
            try {
              const parsed = JSON.parse(payload);
              if (parsed.text) {
                botDiv.textContent += parsed.text;
                gotText = true;
                scrollDown();
              } else if (parsed.error) {
                botDiv.textContent = 'Something went wrong on my end. Please try again or email hello@biashara-pos.com';
                gotText = true;
              }
            } catch { /* ignore malformed chunks */ }
          }
        }

        if (!gotText) {
          botDiv.textContent = 'I didn\'t get a response. Please email hello@biashara-pos.com or message us on WhatsApp.';
        }
      } catch (err) {
        hideTyping();
        botHTML(
          'Sorry, I couldn\'t reach the assistant right now. Reach us on WhatsApp:' +
          '<a class="wa-link" href="' + WA_URL + '" target="_blank" rel="noopener">Chat on WhatsApp →</a>'
        );
        console.error('Chat error:', err);
      } finally {
        setBusy(false);
        input.focus();
      }
    }

    sendBtn.addEventListener('click', () => send());
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });

    // Auto-open with welcome message on first visit (once per session)
    if (!sessionStorage.getItem('bpos-greeted')) {
      setTimeout(() => {
        if (!isOpen) openPanel();
        sessionStorage.setItem('bpos-greeted', '1');
      }, 3000);
    }
  }
</script>
