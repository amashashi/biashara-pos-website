---
---
<section class="py-20 bg-[#F0FDF4]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="fade-in text-center">
      <!-- Green quote mark -->
      <div class="text-8xl text-[#1D9E75] font-800 leading-none mb-4 opacity-40">"</div>

      <!-- Quote -->
      <blockquote class="mb-6">
        <p class="text-2xl sm:text-3xl font-700 text-[#0B3D2E] leading-relaxed mb-4 italic">
          "Naona faida yangu mara moja baada ya kila uuzaji — sijawahi kuwa na hii kabla."
        </p>
        <p class="text-lg text-[#1D9E75] font-600 italic">
          "I see my profit instantly after every sale — I've never had this before."
        </p>
      </blockquote>

      <!-- Attribution -->
      <div class="flex flex-col items-center gap-2">
        <div class="w-12 h-12 rounded-full bg-[#1D9E75] flex items-center justify-center text-white font-800 text-lg">F</div>
        <div>
          <p class="font-800 text-[#1C1C1A] text-base">Fdhyler Collection</p>
          <p class="text-sm text-gray-500 font-600">Dar es Salaam, Tanzania</p>
        </div>
        <div class="flex items-center gap-1 text-[#FFD700]">
          {Array(5).fill(null).map(() => <span>★</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
