---
import { Image } from 'astro:assets';
import logo from '../assets/biashara-logo-trim.png';

const appUrl = 'https://app.biashara-pos.com';
const WA = 'https://wa.me/255754711960?text=Hello%2C%20I%27m%20interested%20in%20BiasharaPOS';
const ROOT = '/';
---
<footer class="footer">
  <div class="wrap">
    <div class="footer-top">
      <div>
        <a class="brand" href="#top" aria-label="BiasharaPOS home">
          <Image src={logo} alt="BiasharaPOS" width={128} height={128} loading="lazy" />
        </a>
        <p
          class="fdesc"
          data-en="Tanzania's only POS with real-time net profit after every sale. TRA-compliant, works offline, flat monthly fee."
          data-sw="POS pekee Tanzania yenye faida halisi ya wakati huo baada ya kila mauzo. Inakubalika TRA, inafanya kazi bila intaneti, ada ya kawaida ya mwezi."
        >Tanzania's only POS with real-time net profit after every sale. TRA-compliant, works offline, flat monthly fee.</p>
        <a class="wa" href={WA} data-en="WhatsApp us" data-sw="Tutumie WhatsApp">WhatsApp us</a>
      </div>
      <div>
        <h4 data-en="Product" data-sw="Bidhaa">Product</h4>
        <ul>
          <li><a href="#why" data-en="Features" data-sw="Vipengele">Features</a></li>
          <li><a href="#pricing" data-en="Pricing" data-sw="Bei">Pricing</a></li>
          <li><a href="#compliance" data-en="Compliance" data-sw="Utii">Compliance</a></li>
          <li><a href="#demo" data-en="Demo" data-sw="Onyesho">Demo</a></li>
          <li><a href={appUrl} data-en="Launch app ↗" data-sw="Fungua app ↗">Launch app ↗</a></li>
        </ul>
      </div>
      <div>
        <h4 data-en="Company" data-sw="Kampuni">Company</h4>
        <ul>
          <li><a href="#top" data-en="About" data-sw="Kuhusu">About</a></li>
          <li><a href={appUrl} data-en="Launch app ↗" data-sw="Fungua app ↗">Launch app ↗</a></li>
          <li><a href="mailto:hello@biashara-pos.com" data-en="Contact" data-sw="Wasiliana">Contact</a></li>
          <li><a href="#faq">FAQ</a></li>
        </ul>
      </div>
      <div>
        <h4 data-en="Legal" data-sw="Sheria">Legal</h4>
        <ul>
          <li><a href={ROOT} data-en="Privacy Policy" data-sw="Sera ya Faragha">Privacy Policy</a></li>
          <li><a href={ROOT} data-en="Terms of Service" data-sw="Masharti ya Huduma">Terms of Service</a></li>
          <li><a href={ROOT} data-en="Cookie Policy" data-sw="Sera ya Cookie">Cookie Policy</a></li>
          <li><a href="#compliance" data-en="Compliance" data-sw="Utii">Compliance</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bot">
      <span data-en="© 2026 BiasharaPOS · Tanzania. All rights reserved." data-sw="© 2026 BiasharaPOS · Tanzania. Haki zote zimehifadhiwa.">© 2026 BiasharaPOS · Tanzania. All rights reserved.</span>
      <span data-en="Smart Business. Seamless Sales." data-sw="Biashara Bora. Mauzo Rahisi.">Smart Business. Seamless Sales.</span>
    </div>
  </div>
</footer>
