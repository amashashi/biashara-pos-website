---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  /** <title> + og:title for the page. */
  title: string;
  /** Meta description. */
  description: string;
  /** Canonical path, e.g. "/privacy". */
  path: string;
  /** Page heading (English). */
  heading: string;
  /** Page heading (Swahili). */
  headingSw: string;
  /** Human-readable "last updated" date, e.g. "10 June 2026". */
  updated: string;
}

const { title, description, path, heading, headingSw, updated } = Astro.props;
---
<Layout title={title} description={description} path={path} faqs={[]}>
  <Nav />
  <main id="top" class="legal">
    <div class="wrap legal-wrap">
      <a class="legal-back" href="/" data-en="← Back to home" data-sw="← Rudi mwanzo">← Back to home</a>
      <h1 data-en={heading} data-sw={headingSw}>{heading}</h1>
      <p class="legal-updated" data-en={`Last updated: ${updated}`} data-sw={`Imesasishwa mwisho: ${updated}`}>Last updated: {updated}</p>
      <article class="legal-body">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal { padding: 120px 0 64px; background: var(--bg); }
  .legal-wrap { max-width: 820px; }
  .legal-back {
    display: inline-block; margin-bottom: 20px; font-size: 14.5px; font-weight: 600;
    color: var(--green-d); text-decoration: none;
  }
  .legal-back:hover { text-decoration: underline; }
  .legal h1 { font-size: clamp(28px, 5vw, 42px); line-height: 1.12; color: var(--ink); margin: 0 0 8px; }
  .legal-updated { font-size: 14px; color: var(--ink-3); margin: 0 0 36px; }
  .legal-body { color: var(--ink-2); font-size: 16px; line-height: 1.7; }
  .legal-body :global(h2) {
    font-size: 21px; font-weight: 800; color: var(--ink); margin: 36px 0 12px;
  }
  .legal-body :global(h2:first-child) { margin-top: 0; }
  .legal-body :global(p) { margin: 0 0 16px; }
  .legal-body :global(ul) { margin: 0 0 16px; padding-left: 22px; }
  .legal-body :global(li) { margin: 0 0 8px; }
  .legal-body :global(a) { color: var(--green-d); font-weight: 600; }
  .legal-body :global(strong) { color: var(--ink); }
  @media (max-width: 600px) { .legal { padding: 96px 0 48px; } }
</style>
