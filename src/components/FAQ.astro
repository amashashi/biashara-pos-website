---
const faqs = [
  {
    qEn: 'Do I need internet to use BiasharaPOS?',
    qSw: 'Je, nahitaji intaneti kutumia BiasharaPOS?',
    aEn: 'No. The system works fully offline. All transactions are saved locally and automatically sync to the cloud when your internet returns.',
    aSw: 'Hapana. Mfumo unafanya kazi kikamilifu bila intaneti. Miamala yote inahifadhiwa ndani na kusawazishwa kwenye wingu kiotomatiki intaneti inarudi.',
  },
  {
    qEn: 'Is BiasharaPOS accepted by TRA?',
    qSw: 'Je, BiasharaPOS inakubaliwa na TRA?',
    aEn: 'Yes. BiasharaPOS integrates with TRA\'s Virtual Fiscal Device (VFD) system. Every sale generates an official RCTVNUM fiscal receipt number. You can also generate a one-click TRA audit PDF report for any period.',
    aSw: 'Ndiyo. BiasharaPOS inaunganishwa na mfumo wa Kifaa cha Fedha cha Mtandao (VFD) wa TRA. Kila uuzaji unazalisha nambari rasmi ya RCTVNUM ya risiti ya fedha.',
  },
  {
    qEn: 'Is there a mobile app?',
    qSw: 'Je, kuna programu ya simu?',
    aEn: 'Yes. Our Flutter Android app supports offline-first selling with a built-in barcode scanner. iOS is coming in Phase 3. You can also use the web app from any browser.',
    aSw: 'Ndiyo. Programu yetu ya Android ya Flutter inasaidia uuzaji bila intaneti na skana ya barcode iliyojengewa ndani. iOS inakuja katika Awamu ya 3. Unaweza pia kutumia programu ya wavuti kutoka kivinjari chochote.',
  },
  {
    qEn: 'Can I use it for my pharmacy / restaurant / supermarket?',
    qSw: 'Je, ninaweza kuitumia kwa duka la dawa / mkahawa / duka kuu langu?',
    aEn: 'Yes. BiasharaPOS Business includes expiry date tracking, purchase orders, and multi-category inventory — built specifically for pharmacies, restaurants, and supermarkets.',
    aSw: 'Ndiyo. BiasharaPOS Business inajumuisha ufuatiliaji wa tarehe ya mwisho, maagizo ya ununuzi, na hesabu za akiba za aina nyingi — iliyojengwa mahsusi kwa maduka ya dawa, mikahawa, na maduka makuu.',
  },
  {
    qEn: 'What payment methods are supported?',
    qSw: 'Njia zipi za malipo zinazungumzwa?',
    aEn: 'Cash, M-Pesa, Tigo Pesa, Airtel Money, Visa, and Mastercard. All accepted from a single system at a flat monthly fee.',
    aSw: 'Taslimu, M-Pesa, Tigo Pesa, Airtel Money, Visa, na Mastercard. Zote zinakubaliwa kutoka mfumo mmoja kwa ada ya mwezi tu.',
  },
];
---
<section id="faq" class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 fade-in">
      <p class="text-[#1D9E75] font-700 text-sm uppercase tracking-widest mb-3">Got questions?</p>
      <h2 class="text-3xl sm:text-4xl font-800 text-[#1C1C1A]">
        <span data-en="Frequently Asked Questions" data-sw="Maswali Yanayoulizwa Mara Kwa Mara">Frequently Asked Questions</span>
      </h2>
    </div>

    <div class="space-y-3 fade-in">
      {faqs.map((faq, i) => (
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <button
            class="faq-trigger w-full flex items-center justify-between px-6 py-4 text-left bg-white hover:bg-[#F8FAFC] transition-colors"
            aria-expanded="false"
          >
            <span class="font-700 text-[#1C1C1A] text-sm sm:text-base pr-4">
              <span data-en={faq.qEn} data-sw={faq.qSw}>{faq.qEn}</span>
            </span>
            <span class="faq-chevron flex-shrink-0 w-6 h-6 text-[#1A56A0] transition-transform duration-200">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
          <div class="faq-content hidden px-6 pb-5 pt-1 bg-[#F8FAFC] border-t border-gray-100">
            <p class="text-gray-600 text-sm leading-relaxed">
              <span data-en={faq.aEn} data-sw={faq.aSw}>{faq.aEn}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
      const isOpen = !content.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-content').forEach((c) => c.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach((c) => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-trigger').forEach((b) => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        content.classList.remove('hidden');
        chevron.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
