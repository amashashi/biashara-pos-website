---
const stats = [
  {
    value: 'TZS 35,000/mo',
    label: 'Flat monthly fee, no surprises',
    labelSw: 'Ada ya mwezi, bila mshangao',
    icon: '💳',
  },
  {
    value: 'TZS 0',
    label: 'Per-transaction fees — flat monthly only',
    labelSw: 'Ada kwa kila muamala — ada ya mwezi tu',
    icon: '🚫',
  },
  {
    value: '< 2 minutes',
    label: 'Setup time to first sale',
    labelSw: 'Muda wa kuanza hadi uuzaji wa kwanza',
    icon: '⚡',
  },
  {
    value: 'TZS 800,000/yr',
    label: 'Maximum TRA accountant savings',
    labelSw: 'Akiba ya juu ya gharama za mhasibu TRA',
    icon: '💰',
  },
];
---
<section class="bg-[#1A56A0] py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="fade-in text-center">
          <div class="text-3xl mb-2">{stat.icon}</div>
          <div class="text-3xl sm:text-4xl font-800 text-white mb-2">{stat.value}</div>
          <div class="text-sm text-blue-200 font-600 leading-snug">
            <span data-en={stat.label} data-sw={stat.labelSw}>{stat.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
