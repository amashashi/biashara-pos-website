---
import '../styles/landing.css';
import ChatWidget from '../components/ChatWidget.astro';

export interface FAQItem { q: string; a: string; }

export interface Props {
  title?: string;
  description?: string;
  /** Path of the current page used for canonical + og:url. Defaults to "/". */
  path?: string;
  /** Per-page FAQ items rendered as FAQPage JSON-LD. Defaults to homepage FAQs. */
  faqs?: FAQItem[];
  /** Additional JSON-LD blocks to inject (e.g. BreadcrumbList on sub-pages). */
  extraJsonLd?: Record<string, unknown>[];
}

const homepageFaqs: FAQItem[] = [
  { q: 'Do I need internet to use BiasharaPOS?', a: 'No. BiasharaPOS works fully offline — sales queue locally and auto-sync the moment you\'re back online.' },
  { q: 'Is BiasharaPOS accepted by TRA?', a: 'Yes. We issue VFD fiscal receipt numbers (RCTVNUM) on every sale and generate one-click TRA audit PDF reports.' },
  { q: 'Is there a mobile app?', a: 'Yes — BiasharaPOS runs on any phone, tablet or computer, with no special hardware required.' },
  { q: 'Can I use it for my pharmacy / restaurant / supermarket?', a: 'Absolutely. Dedicated modes handle expiry & batches for pharmacies, tables & kitchen tickets for restaurants, and barcodes & bulk for retail.' },
  { q: 'What payment methods are supported?', a: 'M-Pesa, Tigo Pesa, Airtel Money, Visa and Mastercard — all at a flat monthly fee with no per-transaction charges.' },
];

const {
  title = 'BiasharaPOS — One POS for every business',
  description = "One POS for every business vertical — clothing, retail, restaurants, hospitals & pharmacies. Real-time net profit after every sale, works offline, TRA-compliant, flat monthly fee.",
  path = '/',
  faqs = homepageFaqs,
  extraJsonLd = [],
} = Astro.props;

const siteUrl = 'https://biashara-pos.com';
const canonical = new URL(path, siteUrl).toString();
const ogImage = new URL('/og-image.png', siteUrl).toString();
const WA_URL = 'https://wa.me/255754711960?text=Hello%2C%20I%27m%20interested%20in%20BiasharaPOS';

const softwareApplicationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'BiasharaPOS',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  description,
  url: siteUrl,
  inLanguage: ['en', 'sw'],
  offers: [
    { '@type': 'Offer', name: 'Free',     price: '0',     priceCurrency: 'TZS', priceSpecification: { '@type': 'UnitPriceSpecification', price: '0', priceCurrency: 'TZS', billingDuration: 'P1M' } },
    { '@type': 'Offer', name: 'Pro',      price: '35000', priceCurrency: 'TZS', priceSpecification: { '@type': 'UnitPriceSpecification', price: '35000', priceCurrency: 'TZS', billingDuration: 'P1M' } },
    { '@type': 'Offer', name: 'Business', price: '85000', priceCurrency: 'TZS', priceSpecification: { '@type': 'UnitPriceSpecification', price: '85000', priceCurrency: 'TZS', billingDuration: 'P1M' } },
  ],
};

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'BiasharaPOS',
  url: siteUrl,
  logo: new URL('/biashara-logo-trim.png', siteUrl).toString(),
  areaServed: { '@type': 'Country', name: 'Tanzania' },
  contactPoint: [{
    '@type': 'ContactPoint',
    contactType: 'customer support',
    telephone: '+255754711960',
    email: 'hello@biashara-pos.com',
    availableLanguage: ['en', 'sw'],
  }],
  sameAs: [],
};

const faqPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-74MCNRL92X"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-74MCNRL92X');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#239b46" />
    <link rel="canonical" href={canonical} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="BiasharaPOS" />
    <meta property="og:locale" content="en_TZ" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BiasharaPOS — One POS for every business" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "favicon.png"} />
    <link rel="apple-touch-icon" href={import.meta.env.BASE_URL + "biashara-logo-trim.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- Structured data: SoftwareApplication, Organization, FAQPage, + page-specific -->
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqPageJsonLd)} />
    {extraJsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <slot />

    <!-- Floating WhatsApp button (right) -->
    <a class="fab fab-wa" href={WA_URL} target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.18-3 .94.95-2.92-.2-.3A8 8 0 1 1 12 20z"/>
        <path d="M17.5 14.4c-.3-.15-1.7-.84-2-.93-.27-.1-.47-.15-.66.15-.2.3-.76.92-.93 1.11-.17.2-.34.22-.64.08-.3-.15-1.26-.47-2.4-1.49-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.65-1.6-.9-2.18-.23-.56-.47-.49-.65-.5h-.56c-.2 0-.51.08-.78.38-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.06 2.87 1.21 3.07.15.2 2.09 3.2 5.07 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.7-.7 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.27-.19-.56-.33z"/>
      </svg>
    </a>
    <span class="fab-tip tip-wa">Chat on WhatsApp</span>

    <!-- Biashara Bot chat widget (left FAB + panel) -->
    <ChatWidget />

    <!-- Industry switcher data + render, FAQ accordion, nav scroll shadow, reveal-on-scroll -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js');

        /* ---------- industry switcher data ---------- */
        var VERT = {
          clothing: {
            cat: 'Clothing · POS', mode: 'Boutique / fashion', tag: 'Sizes & variants',
            net: '+TZS 6,800', sales: 'TZS 612,000', tx: '18',
            products: [
              ['Cotton T-Shirt', '15,000', '#dbe7fb'], ['Kitenge Dress', '48,000', '#e6f6ea'],
              ['Denim Jeans', '35,000', '#dcefe6'], ['Sneakers', '62,000', '#fbeedd'],
              ['Leather Belt', '18,000', '#e9e7fb'], ['Hoodie', '40,000', '#d9f0f6']
            ]
          },
          retail: {
            cat: 'Retail · POS', mode: 'General store', tag: 'Barcodes & bulk',
            net: '+TZS 4,200', sales: 'TZS 847,500', tx: '24',
            products: [
              ['Sugar 1kg', '3,200', '#e6f6ea'], ['Cooking Oil 2L', '9,500', '#fbeedd'],
              ['Soap Bar', '1,500', '#dbe7fb'], ['Rice 5kg', '22,000', '#dcefe6'],
              ['Soda Crate', '16,000', '#d9f0f6'], ['AA Batteries', '2,000', '#e9e7fb']
            ]
          },
          restaurant: {
            cat: 'Restaurant · POS', mode: 'Dine-in & takeaway', tag: 'Tables & kitchen',
            net: '+TZS 3,400', sales: 'TZS 528,000', tx: '36',
            products: [
              ['Nyama Choma', '18,000', '#fbeedd'], ['Chips Mayai', '7,000', '#fdf3df'],
              ['Pilau', '9,000', '#e6f6ea'], ['Chapati', '1,000', '#dcefe6'],
              ['Soda', '1,500', '#dbe7fb'], ['Fresh Juice', '4,000', '#d9f0f6']
            ]
          },
          hospital: {
            cat: 'Hospital · POS', mode: 'Clinic & billing', tag: 'Patients & billing',
            net: '+TZS 12,500', sales: 'TZS 1,240,000', tx: '14',
            products: [
              ['Consultation', '20,000', '#dbe7fb'], ['Malaria Test', '8,000', '#e6f6ea'],
              ['X-Ray', '45,000', '#dcefe6'], ['Lab Panel', '35,000', '#d9f0f6'],
              ['Bed / day', '60,000', '#e9e7fb'], ['Wound Dressing', '6,000', '#fbeedd']
            ]
          },
          pharmacy: {
            cat: 'Pharmacy · POS', mode: 'Dispensary', tag: 'Expiry & batches',
            net: '+TZS 5,100', sales: 'TZS 392,000', tx: '29',
            products: [
              ['Paracetamol', '2,500', '#e6f6ea'], ['Amoxicillin', '7,000', '#dbe7fb'],
              ['ORS Sachet', '1,200', '#dcefe6'], ['Bandage Roll', '3,500', '#fbeedd'],
              ['Vitamin C', '5,000', '#fdf3df'], ['Cough Syrup', '8,500', '#d9f0f6']
            ]
          }
        };

        var grid = document.getElementById('prodGrid');
        var elCat = document.getElementById('posCat');
        var elMode = document.getElementById('posMode');
        var elTag = document.getElementById('posTag');
        var elNet = document.getElementById('netAmt');
        var elSales = document.getElementById('sumSales');
        var elTx = document.getElementById('sumTx');

        function render(key) {
          var v = VERT[key];
          if (!v || !grid) return;
          if (elCat && elCat.firstChild) elCat.firstChild.textContent = v.cat + ' ';
          if (elMode) elMode.textContent = v.mode;
          if (elTag) elTag.textContent = v.tag;
          if (elNet) elNet.textContent = v.net;
          if (elSales) elSales.textContent = v.sales;
          if (elTx) elTx.textContent = v.tx;
          grid.innerHTML = v.products.map(function (p) {
            return '<div class="prod"><div class="sw-img" style="background:linear-gradient(135deg,' + p[2] + ',#ffffff)"></div>' +
              '<div class="pn">' + p[0] + '</div><div class="pp">TZS ' + p[1] + '</div></div>';
          }).join('');
        }

        var tabs = document.querySelectorAll('.switch-tab');
        tabs.forEach(function (t) {
          t.addEventListener('click', function () {
            tabs.forEach(function (x) { x.classList.remove('active'); });
            t.classList.add('active');
            render(t.dataset.v);
          });
        });
        render('retail');

        /* ---------- FAQ accordion ---------- */
        document.querySelectorAll('#faqList .faq').forEach(function (f) {
          var btn = f.querySelector('button');
          if (!btn) return;
          btn.addEventListener('click', function () {
            var open = f.classList.contains('open');
            document.querySelectorAll('#faqList .faq').forEach(function (x) { x.classList.remove('open'); });
            if (!open) f.classList.add('open');
          });
        });

        /* ---------- nav shadow on scroll ---------- */
        var nav = document.getElementById('nav');
        function onScroll() { if (nav) nav.classList.toggle('scrolled', window.scrollY > 12); }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        /* ---------- mobile nav menu ---------- */
        var burger = document.getElementById('navBurger');
        var menu = document.getElementById('navMenu');
        if (burger && menu) {
          burger.addEventListener('click', function () {
            var open = menu.classList.toggle('open');
            burger.classList.toggle('open', open);
            burger.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
          menu.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () {
              menu.classList.remove('open');
              burger.classList.remove('open');
              burger.setAttribute('aria-expanded', 'false');
            });
          });
        }

        /* ---------- reveal on scroll (with failsafe + prefers-reduced-motion) ---------- */
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
          document.querySelectorAll('.reveal').forEach(function (el, i) {
            el.style.transitionDelay = Math.min(i % 6, 5) * 60 + 'ms';
            io.observe(el);
          });
        }
        // failsafe: never leave content hidden if observer/transition doesn't advance
        setTimeout(function () {
          document.documentElement.classList.add('reveal-all');
        }, 900);
      })();
    </script>

    <!-- Bilingual EN/SW toggle -->
    <script is:inline>
      (function () {
        function applyLang(lang) {
          document.documentElement.lang = lang;
          document.body.classList.toggle('lang-sw', lang === 'sw');
          document.querySelectorAll('[data-en]').forEach(function (el) {
            var enText = el.getAttribute('data-en');
            var swText = el.getAttribute('data-sw');
            var text = lang === 'sw' ? (swText || enText) : enText;
            if (text == null) return;
            // Use innerHTML so inline <span class="sw">...</span> phrases render correctly
            if (text.indexOf('<') !== -1) el.innerHTML = text;
            else el.textContent = text;
          });
          document.querySelectorAll('[data-lang-toggle]').forEach(function (btn) {
            btn.textContent = lang === 'en' ? 'SW' : 'EN';
          });
          try { localStorage.setItem('biashara-lang', lang); } catch (e) {}
        }
        document.querySelectorAll('[data-lang-toggle]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var current = document.documentElement.lang || 'en';
            applyLang(current === 'en' ? 'sw' : 'en');
          });
        });
        try {
          var saved = localStorage.getItem('biashara-lang');
          if (saved && saved !== 'en') applyLang(saved);
        } catch (e) {}
      })();
    </script>

    <!-- Conversion event tracking (GA4) -->
    <script is:inline>
      (function () {
        function track(name, params) {
          if (typeof window.gtag === 'function') window.gtag('event', name, params);
        }
        function nearestText(el) {
          var node = el.closest('a, button');
          return node ? (node.textContent || '').trim().slice(0, 80) : '';
        }
        document.addEventListener('click', function (e) {
          var link = e.target.closest('a, button');
          if (!link) return;
          var href = link.getAttribute('href') || '';
          if (href.indexOf('wa.me') !== -1 || href.indexOf('whatsapp') !== -1) {
            track('whatsapp_click', { link_url: href, link_text: nearestText(link) });
          } else if (href.indexOf('app.biashara-pos.com') !== -1) {
            track('app_cta_click', { link_url: href, link_text: nearestText(link) });
          } else if (href.indexOf('mailto:') === 0) {
            track('contact_email_click', { link_url: href });
          } else if (link.id === 'botFab') {
            track('chat_widget_open', {});
          }
        });
      })();
    </script>
  </body>
</html>
