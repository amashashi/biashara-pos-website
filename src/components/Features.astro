---
const features = [
  {
    badge: { en: "Tanzania's only", sw: "Pekee Tanzania" },
    blue: false,
    en: { title: 'Real-time profit', desc: 'Net profit after COGS, expenses & VAT shown after every single sale.' },
    sw: { title: 'Faida ya papo hapo', desc: 'Faida halisi baada ya gharama, matumizi na VAT inaonyeshwa baada ya kila mauzo.' },
    icon: '<path d="M4 19V5M4 19h16M8 16l3-4 3 2 4-6"/>',
  },
  {
    blue: true,
    en: { title: 'Works offline', desc: 'Sell without internet. Transactions queue locally and auto-sync when you reconnect.' },
    sw: { title: 'Inafanya kazi bila intaneti', desc: 'Uza bila intaneti. Miamala inahifadhiwa ndani na inasawazishwa ukirudisha intaneti.' },
    icon: '<path d="M5 13a10 10 0 0 1 14 0M8.5 16.5a5 5 0 0 1 7 0M12 20h.01M2 8.8a16 16 0 0 1 20 0"/><line x1="3" y1="3" x2="21" y2="21"/>',
  },
  {
    blue: false,
    en: { title: 'TRA-native compliance', desc: 'VFD fiscal receipt numbers on every sale. One-click TRA audit PDF reports.' },
    sw: { title: 'Utii wa TRA', desc: 'Namba za risiti za kodi VFD kwa kila mauzo. Ripoti za ukaguzi wa TRA PDF kwa mguso mmoja.' },
    icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    blue: true,
    en: { title: 'Universal payments', desc: 'M-Pesa, Mixx by Yas, Airtel, Visa & Mastercard — all at a flat fee, no per-transaction charge.' },
    sw: { title: 'Malipo ya aina zote', desc: 'M-Pesa, Mixx by Yas, Airtel, Visa na Mastercard — yote kwa ada ya kawaida, bila ada ya kila muamala.' },
    icon: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
  },
  {
    blue: false,
    en: { title: 'Smart inventory', desc: 'Stock tracking, low-stock alerts, expiry monitoring and purchase orders.' },
    sw: { title: 'Stoki mahiri', desc: 'Ufuatiliaji wa stoki, tahadhari za stoki ndogo, ufuatiliaji wa mwisho wa muda na maagizo ya ununuzi.' },
    icon: '<path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/>',
  },
  {
    blue: true,
    en: { title: 'Multi-user roles', desc: 'Admin, manager & cashier roles with PIN login and a full audit trail.' },
    sw: { title: 'Watumiaji wengi', desc: 'Majukumu ya msimamizi, meneja na kasha na PIN login na ufuatiliaji kamili.' },
    icon: '<circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0M16 6a3 3 0 0 1 0 6M21 20a5 5 0 0 0-4-5"/>',
  },
];
---
<section class="sec sec-tint" id="why">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="Why BiasharaPOS" data-sw="Kwa nini BiasharaPOS">Why BiasharaPOS</span>
      <h2 data-en="Everything a shop needs" data-sw="Kila kitu duka linahitaji">Everything a shop needs</h2>
      <p data-en="One platform that replaces your till, your stock book and your accountant's headaches." data-sw="Jukwaa moja linalochukua nafasi ya kasha, kitabu cha stoki na maumivu ya kichwa ya mhasibu wako.">One platform that replaces your till, your stock book and your accountant's headaches.</p>
    </div>
    <div class="fgrid">
      {features.map((f) => (
        <div class={`feat reveal ${f.blue ? 'blue' : ''}`}>
          {f.badge && (<span class="badge" data-en={f.badge.en} data-sw={f.badge.sw}>{f.badge.en}</span>)}
          <div class="fi" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${f.icon}</svg>`}></div>
          <h3 data-en={f.en.title} data-sw={f.sw.title}>{f.en.title}</h3>
          <p data-en={f.en.desc} data-sw={f.sw.desc}>{f.en.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
