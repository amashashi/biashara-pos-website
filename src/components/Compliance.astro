---
const cards = [
  { status: { en: 'Active', sw: 'Inafanya kazi' }, cls: 'on', en: { title: 'TRA VFD integrated', desc: 'Automatic fiscal receipt numbers (RCTVNUM) on every sale.' }, sw: { title: 'TRA VFD imeunganishwa', desc: 'Namba za risiti za kodi (RCTVNUM) moja kwa moja kwa kila mauzo.' }, icon: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>' },
  { status: { en: 'Active', sw: 'Inafanya kazi' }, cls: 'on', en: { title: 'NF525 receipt chain', desc: 'Tamper-proof cryptographic receipt chain for audit integrity.' }, sw: { title: 'Mnyororo wa risiti NF525', desc: 'Mnyororo wa risiti usioweza kubadilishwa kwa uadilifu wa ukaguzi.' }, icon: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/>' },
  { status: { en: 'In progress', sw: 'Inaendelea' }, cls: 'prog', en: { title: 'ISO 27001', desc: 'Audit log, access control and incident-response framework.' }, sw: { title: 'ISO 27001', desc: 'Kumbukumbu za ukaguzi, udhibiti wa ufikiaji na muundo wa majibu ya tukio.' }, icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>' },
  { status: { en: 'Aligned', sw: 'Imeshirikiana' }, cls: 'on', en: { title: 'PCI DSS', desc: 'No card data stored. TLS encryption with tokenised payments.' }, sw: { title: 'PCI DSS', desc: 'Hakuna data ya kadi inayohifadhiwa. Usimbaji wa TLS na malipo ya tokeni.' }, icon: '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18M7 15h4"/>' },
];
---
<section class="sec sec-white" id="compliance">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow center" data-en="Compliant by design" data-sw="Utii wa muundo">Compliant by design</span>
      <h2 data-en="Audit-ready from day one" data-sw="Tayari kwa ukaguzi tangu siku ya kwanza">Audit-ready from day one</h2>
      <p data-en="Built for TRA, NF525, ISO 27001 and PCI DSS — so you're covered as you grow." data-sw="Imejengwa kwa TRA, NF525, ISO 27001 na PCI DSS — ili uwe salama unapokua.">Built for TRA, NF525, ISO 27001 and PCI DSS — so you're covered as you grow.</p>
    </div>
    <div class="comp-grid">
      {cards.map((c) => (
        <div class="comp-card reveal">
          <div class="ch">
            <div class="cico" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${c.icon}</svg>`}></div>
            <span class={`status ${c.cls}`} data-en={c.status.en} data-sw={c.status.sw}>{c.status.en}</span>
          </div>
          <h3 data-en={c.en.title} data-sw={c.sw.title}>{c.en.title}</h3>
          <p data-en={c.en.desc} data-sw={c.sw.desc}>{c.en.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
