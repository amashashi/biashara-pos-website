---
import { Image } from 'astro:assets';
import logo from '../assets/biashara-logo-trim.png';

const appUrl = 'https://app.biashara-pos.com';
---
<header class="nav" id="nav">
  <div class="wrap nav-in">
    <a class="brand" href="/#top" aria-label="BiasharaPOS home">
      <Image src={logo} alt="BiasharaPOS" width={92} height={92} loading="eager" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#industries" data-en="Industries" data-sw="Sekta">Industries</a>
      <a href="#devices" data-en="Devices" data-sw="Vifaa">Devices</a>
      <a href="#why" data-en="Features" data-sw="Vipengele">Features</a>
      <a href="#pricing" data-en="Pricing" data-sw="Bei">Pricing</a>
      <a href="#compliance" data-en="Compliance" data-sw="Utii">Compliance</a>
    </nav>
    <div class="nav-cta">
      <button class="lang-toggle" data-lang-toggle aria-label="Switch language">SW</button>
      <a class="signin" href={appUrl} data-en="Sign in" data-sw="Ingia">Sign in</a>
      <a class="btn btn-primary" href={appUrl} data-en="Start Free →" data-sw="Anza Bila Malipo →">Start Free →</a>
      <button class="nav-burger" id="navBurger" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="nav-menu" id="navMenu">
    <a href="#industries" data-en="Industries" data-sw="Sekta">Industries</a>
    <a href="#devices" data-en="Devices" data-sw="Vifaa">Devices</a>
    <a href="#why" data-en="Features" data-sw="Vipengele">Features</a>
    <a href="#pricing" data-en="Pricing" data-sw="Bei">Pricing</a>
    <a href="#compliance" data-en="Compliance" data-sw="Utii">Compliance</a>
    <a class="menu-signin" href={appUrl} data-en="Sign in" data-sw="Ingia">Sign in</a>
    <a class="btn btn-primary" href={appUrl} data-en="Start Free →" data-sw="Anza Bila Malipo →">Start Free →</a>
  </div>
</header>
