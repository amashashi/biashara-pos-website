---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProductPreview from '../components/ProductPreview.astro';
import Industries from '../components/Industries.astro';
import Devices from '../components/Devices.astro';
import ProfitSpotlight from '../components/ProfitSpotlight.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Comparison from '../components/Comparison.astro';
import Compliance from '../components/Compliance.astro';
import Pricing from '../components/Pricing.astro';
import TestimonialFAQ from '../components/TestimonialFAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="BiasharaPOS — One POS for every business"
  description="One POS for every business vertical — clothing, retail, restaurants, hospitals & pharmacies. Real-time net profit after every sale, works offline, TRA-compliant, flat monthly fee."
>
  <Nav />
  <main id="top">
    <Hero />
    <ProductPreview />
    <Industries />
    <Devices />
    <ProfitSpotlight />
    <Features />
    <HowItWorks />
    <Comparison />
    <Compliance />
    <Pricing />
    <TestimonialFAQ />
    <CTA />
  </main>
  <Footer />
</Layout>
